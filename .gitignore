# ============================================================
#  D&D AI Companion — fichiers exclus du suivi git
#  (artefacts de build, caches, environnements, données générées)
# ============================================================

# ---- Secrets & variables d'environnement ----
.env
.env.*
!.env.example
secret_api_keys.py

# ---- Python : caches & artefacts de build ----
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
build/
dist/
develop-eggs/
.eggs/
sdist/
wheels/
.installed.cfg
MANIFEST

# ---- Environnements virtuels (racine + serveurs MCP imbriqués) ----
.venv/
venv/
env/
ENV/
**/.venv/
**/venv/

# ---- Caches d'outils (tests, typage, lint, couverture) ----
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.coverage
htmlcov/
.cache/

# ---- Node / frontend ----
node_modules/
**/node_modules/
frontend/dist/
dist/
npm-debug.log*
yarn-error.log*

# ---- Bases de données locales (dev) ----
*.db
*.db-journal
*.sqlite
*.sqlite3

# ---- Journaux ----
*.log
logs/
**/logs/

# ---- RAG : données générées / uploadées (régénérées au runtime) ----
rag/uploads/
rag/index/

# ---- Verrous d'environnement redondants (les images Docker gèrent les deps) ----
uv.lock
**/uv.lock

# ---- Serveurs MCP : artefacts de dev (le code source reste suivi) ----
src/*.egg-info/
src/mcp_servers/**/build/
src/mcp_servers/**/*.egg-info/
src/mcp_servers/**/.roo/
src/mcp_servers/**/dnd_data/
src/mcp_servers/**/demo_data/

# ---- Code mort / expérimentations (non utilisés par l'application) ----
src/mcp_servers/dnd_sources_mcp/Archive/
src/my_mcp_client/python-sdk/
streamlit_legacy/
maquette_frontend/
.streamlit/
